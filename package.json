{
  "name": "xrayai",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:migrate": "cd infra && ./migrate.sh",
    "docker:up": "cd infra && docker-compose up -d",
    "docker:down": "cd infra && docker-compose down",
    "docker:prod": "cd infra && docker-compose -f docker-compose.yml -f docker-compose.prod.yml up -d"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "packageManager": "npm@10.9.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
