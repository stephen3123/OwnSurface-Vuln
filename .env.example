# Database
# Ports are offset to avoid conflict with OwnStamps (5432->5433, 6379->6380, 4222->4223)
DATABASE_URL=postgresql://xrayai:xrayai@localhost:5433/xrayai

# Dragonfly (Redis-compatible cache)
DRAGONFLY_URL=redis://localhost:6380

# NATS
NATS_URL=nats://localhost:4223

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# AWS SES auth mail
AWS_REGION=eu-north-1
AWS_SES_FROM_EMAIL=no-reply@ownsurface.com
AWS_SES_FROM_NAME=OwnSurface
AWS_SES_CONFIGURATION_SET=auth-otp-prod
OTP_HMAC_SECRET=replace-with-a-long-random-secret
OTP_TTL_SECONDS=600
OTP_RESEND_COOLDOWN_SECONDS=60

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_ALLOWED_PRICE_IDS=price_monthly_id,price_annual_id

# Stripe Price IDs (used by Next.js dashboard)
NEXT_PUBLIC_STRIPE_PRICE_PRO=price_monthly_id
NEXT_PUBLIC_STRIPE_PRICE_PRO_ANNUAL=price_annual_id

# Email (Brevo — used for auth OTP and monitoring alerts)
BREVO_API_KEY=xkeysib-...
BREVO_FROM_EMAIL=no-reply@ownsurface.com
BREVO_FROM_NAME=OwnSurface

# Production mode (set to "production" to enforce secret validation)
RUST_ENV=development

# AI (Claude API for summaries)
CLAUDE_API_KEY=sk-ant-...

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001,chrome-extension://your-extension-id

# API Server
PORT=8080
RUST_LOG=info

# Dashboard
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Worker
WORKER_CONCURRENCY=3
SCAN_TIMEOUT_MS=45000
