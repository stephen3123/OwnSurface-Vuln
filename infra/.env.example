# ═══════════════════════════════════════════════════════════
#  XrayAI Production Environment Variables
#  Copy to .env and fill in real values
# ═══════════════════════════════════════════════════════════

# ── Database ──
POSTGRES_USER=xrayai
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=xrayai
DATABASE_URL=postgresql://xrayai:CHANGE_ME_STRONG_PASSWORD@postgres:5432/xrayai

# ── Cache & Queue ──
DRAGONFLY_URL=redis://dragonfly:6379
NATS_URL=nats://nats:4222

# ── Auth ──
JWT_SECRET=CHANGE_ME_RANDOM_64_CHAR_SECRET

# ── Stripe Billing ──
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_PRO_MONTHLY=price_CHANGE_ME
STRIPE_PRICE_PRO_ANNUAL=price_CHANGE_ME
STRIPE_PRICE_BUSINESS_MONTHLY=price_CHANGE_ME

# ── AI via AWS Bedrock (uses IAM credentials, no API key needed on EC2) ──
ENABLE_AI_SUMMARY=true
AWS_BEDROCK_REGION=us-east-1
# BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0  # default, cheapest+best
# AWS_ACCESS_KEY_ID=     # only needed for local dev, EC2 uses instance role
# AWS_SECRET_ACCESS_KEY= # only needed for local dev, EC2 uses instance role

# ── Email (optional — for notifications) ──
SENDGRID_API_KEY=

# ── CORS ──
CORS_ORIGINS=https://ownsurface.com,https://www.ownsurface.com,http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# ── Worker ──
WORKER_CONCURRENCY=2
SCAN_TIMEOUT_MS=45000
LOG_LEVEL=info

# ── Dashboard (set in Vercel, not here) ──
# NEXT_PUBLIC_API_URL=https://api.ownsurface.com
